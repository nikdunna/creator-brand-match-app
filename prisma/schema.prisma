generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id              String         @id @default(cuid())
  companyName     String
  industry        String
  targetAudience  String
  creatorCriteria String
  createdAt       DateTime       @default(now())
  matches         CreatorMatch[]
}

model CreatorMatch {
  id           String   @id @default(cuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name         String
  platform     String
  handle       String
  niche        String
  audienceSize String
  oneLiner     String
  matchReason  String
  avatarUrl    String
  createdAt    DateTime @default(now())
}
